---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/config";

const extractMomentImages = (body: string) => {
  const images: { src: string; alt: string }[] = [];
  const regex = /!\[([^\]]*)\]\(([^)]+)\)/g;
  let match: RegExpExecArray | null = null;

  while ((match = regex.exec(body)) && images.length < 9) {
    const alt = match[1]?.trim();
    const raw = match[2].trim();
    const src = raw.split(/\s+/)[0].replace(/^<|>$/g, "");
    if (src) {
      images.push({ src, alt: alt || "moment image" });
    }
  }

  return images;
};

const extractBilibiliIds = (body: string) => {
  const ids = new Set<string>();
  const regex = /\{video:bilibili\}\(\s*(BV[0-9A-Za-z]{10})\s*\)/gi;
  let match: RegExpExecArray | null = null;

  while ((match = regex.exec(body)) && ids.size < 6) {
    ids.add(match[1]);
  }

  return Array.from(ids);
};

export const getStaticPaths = (async ({ paginate }) => {
  const moments = await getCollection("moments", ({ data }) => !data.draft);
  const sortedMoments = moments.sort(
    (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
  );
  return paginate(sortedMoments, { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const allTags = Array.from(
  new Set(
    page.data
      .flatMap(moment => moment.data.tags ?? [])
      .map(tag => tag.trim())
      .filter(Boolean)
  )
).sort((a, b) => a.localeCompare(b, "zh-Hans-CN"));

const renderedMoments = await Promise.all(
  page.data.map(async moment => {
    const { Content } = await render(moment);
    const images = extractMomentImages(moment.body ?? "");
    const bilibiliIds = extractBilibiliIds(moment.body ?? "");
    const title = moment.data.title?.trim();
    const tags = (moment.data.tags ?? [])
      .map(item => item.trim())
      .filter(Boolean);
    return { moment, Content, images, title, tags, bilibiliIds };
  })
);
---

<Layout title={`Time | ${SITE.title}`} description="记录生活的片刻心情与想法。">
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-16">
    <!--<div class="moments-header">-->
    <!--  <h1 class="moments-page-title">片刻</h1>-->
    <!--  <p class="moments-page-subtitle">像朋友圈一样，记录一些日常与想法。</p>-->
    <!--</div>-->

    {
      allTags.length ? (
        <div class="moment-filters" data-moment-filters>
          <button class="filter-chip is-active" type="button" data-tag="all">
            全部
          </button>
          {allTags.map(tag => (
            <button class="filter-chip" type="button" data-tag={tag}>
              {tag}
            </button>
          ))}
        </div>
      ) : null
    }

    <section class="moments-feed" aria-live="polite">
      {
        renderedMoments.length ? (
          renderedMoments.map(
            ({ moment, Content, images, title, tags, bilibiliIds }) => (
            <article
              class:list={["moment-card", { "has-grid": images.length }]}
              data-moment-card
              data-tags={tags.join(",")}
            >
              <header class="moment-header">
                <div class="moment-avatar">
                  <img
                    src={SITE.authorImage}
                    alt={`${SITE.author} avatar`}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="moment-meta">
                  <span class="moment-author">{SITE.author}</span>
                  <time
                    class="moment-time"
                    datetime={moment.data.pubDatetime.toISOString()}
                  >
                    {moment.data.pubDatetime.toLocaleDateString("zh-CN")}
                  </time>
                  {
                    moment.data.location && (
                      <span class="moment-location">
                        {moment.data.location}
                      </span>
                    )
                  }
                </div>
              </header>
              <div class="moment-body">
                {
                  (title || tags.length) && (
                    <div class="moment-title-row">
                      {title && <h2 class="moment-title">{title}</h2>}
                      {
                        tags.length ? (
                          <div class="moment-tags">
                            {tags.map(item => (
                              <span class="moment-tag">{item}</span>
                            ))}
                          </div>
                        ) : null
                      }
                    </div>
                  )
                }
                <div class="moment-content app-prose">
                  <Content />
                </div>
                {
                  bilibiliIds.length ? (
                    <div class="moment-videos">
                      {bilibiliIds.map(bvid => (
                        <div class="moment-video">
                          <iframe
                            src={`https://player.bilibili.com/player.html?bvid=${bvid}&page=1&high_quality=1&danmaku=0`}
                            allowfullscreen
                            loading="lazy"
                          ></iframe>
                        </div>
                      ))}
                    </div>
                  ) : null
                }
                {
                  images.length ? (
                    <div
                      class="moment-grid"
                      data-grid={images.length}
                      style={`--grid-cols:${Math.min(3, images.length)}`}
                    >
                      {images.map(image => (
                        <img
                          src={image.src}
                          alt={image.alt}
                          loading="lazy"
                          decoding="async"
                        />
                      ))}
                    </div>
                  ) : null
                }
              </div>
            </article>
          ))
        ) : (
          <div class="moment-empty">
            <p>还没有发布片刻。</p>
          </div>
        )
      }
    </section>

    <div class="moment-pagination">
      <Pagination {page} />
    </div>
  </main>
  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<style>
  .moments-header {
    margin: 1rem 0 1.5rem;
  }

  .moments-page-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .moments-page-subtitle {
    margin-top: 0.4rem;
    color: color-mix(in srgb, var(--color-foreground) 65%, transparent);
  }

  .moments-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .moment-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .filter-chip {
    border: 1px solid color-mix(in srgb, var(--color-border) 35%, transparent);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    background: color-mix(in srgb, var(--color-background) 90%, transparent);
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    transition: all 0.2s ease;
  }

  .filter-chip:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    color: var(--color-accent);
  }

  .filter-chip.is-active {
    border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
  }

  .moment-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-border) 20%, transparent);
  }

  .moment-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .moment-avatar img {
    width: 44px;
    height: 44px;
    border-radius: 0.75rem;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--color-border) 30%, transparent);
  }

  .moment-body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .moment-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.6rem;
  }

  .moment-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .moment-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.6rem;
    align-items: center;
  }

  .moment-author {
    font-weight: 600;
    color: var(--color-accent);
  }

  .moment-time {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .moment-location {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .moment-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .moment-tag {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.3rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
  }

  .moment-content :global(p) {
    margin: 0.6rem 0 0;
  }

  .moment-card.has-grid .moment-content :global(img) {
    display: none;
  }

  .moment-videos {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .moment-video {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border) 25%, transparent);
    background: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  .moment-video iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .moment-grid {
    margin-top: 0.75rem;
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 3), minmax(0, 1fr));
    gap: 0.35rem;
    width: fit-content;
    max-width: 380px;
  }

  .moment-grid img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 25%, transparent);
  }

  .moment-grid[data-grid="1"] {
    max-width: 280px;
  }

  .moment-grid[data-grid="1"] img {
    aspect-ratio: 4 / 3;
  }

  .moment-empty {
    padding: 2.5rem 1.5rem;
    border-radius: 1rem;
    text-align: center;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    border: 1px dashed color-mix(in srgb, var(--color-border) 35%, transparent);
  }

  .moment-pagination {
    margin-top: 2rem;
  }

  @media (max-width: 640px) {
    .moment-card {
      padding: 1rem 0;
    }

    .moment-avatar img {
      width: 40px;
      height: 40px;
      border-radius: 0.65rem;
    }
  }
</style>

<script>
  const initMomentFilters = () => {
    const filterWrap = document.querySelector("[data-moment-filters]");
    if (!filterWrap) return;

    const chips = Array.from(
      filterWrap.querySelectorAll<HTMLButtonElement>("[data-tag]")
    );
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-moment-card]")
    );

    const applyFilter = (tag: string) => {
      chips.forEach(chip => {
        chip.classList.toggle("is-active", chip.dataset.tag === tag);
      });

      cards.forEach(card => {
        const tags = (card.dataset.tags || "")
          .split(",")
          .map(item => item.trim())
          .filter(Boolean);
        const visible = tag === "all" || tags.includes(tag);
        card.style.display = visible ? "" : "none";
      });
    };

    chips.forEach(chip => {
      chip.addEventListener("click", () => {
        applyFilter(chip.dataset.tag || "all");
      });
    });
  };

  const setupMomentPage = () => {
    initMomentFilters();
  };

  document.addEventListener("astro:page-load", setupMomentPage);
  document.addEventListener("astro:after-swap", setupMomentPage);
</script>
